@using SistemaNominaMVC.Helpers
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Sistema de Nómina</title>

    <!-- Bootstrap CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/css/bootstrap.min.css" />

    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

    <!-- Custom CSS -->
    <style>
        :root {
            --primary-color: #4e73df;
            --secondary-color: #858796;
            --success-color: #1cc88a;
            --info-color: #36b9cc;
            --warning-color: #f6c23e;
            --danger-color: #e74a3b;
        }

        body {
            background-color: #f8f9fc;
            font-family: 'Nunito', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
        }

        .navbar-brand {
            font-weight: 800;
            letter-spacing: 0.05em;
            text-transform: uppercase;
        }

        .navbar-dark.bg-primary {
            background: linear-gradient(135deg, var(--primary-color) 0%, #224abe 100%) !important;
            box-shadow: 0 0.15rem 1.75rem 0 rgba(58, 59, 69, 0.15);
        }

        .nav-link {
            font-weight: 600;
            font-size: 0.9rem;
            padding: 0.5rem 1rem !important;
            transition: all 0.2s;
        }

        .nav-link:hover {
            background-color: rgba(255, 255, 255, 0.1);
            border-radius: 0.375rem;
        }

        .nav-link i {
            margin-right: 0.5rem;
            font-size: 0.9rem;
        }

        .dropdown-menu {
            border: none;
            box-shadow: 0 0.15rem 1.75rem 0 rgba(58, 59, 69, 0.15);
            border-radius: 0.35rem;
            min-width: 12rem;
            animation: dropdownFade 0.2s;
        }

        @@keyframes dropdownFade {
            from {
                opacity: 0;
                transform: translateY(-10px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .dropdown-item {
            font-weight: 500;
            font-size: 0.85rem;
            padding: 0.5rem 1.5rem;
        }

        .dropdown-item i {
            margin-right: 0.5rem;
            width: 1.25rem;
            color: var(--primary-color);
        }

        .dropdown-item:hover {
            background-color: #eaecf4;
        }

        .badge {
            font-weight: 600;
            padding: 0.35em 0.65em;
            font-size: 0.75em;
        }

        .alert {
            border: none;
            border-radius: 0.35rem;
            box-shadow: 0 0.15rem 1.75rem 0 rgba(58, 59, 69, 0.1);
            animation: alertSlide 0.3s;
        }

        @@keyframes alertSlide {
            from {
                transform: translateY(-20px);
                opacity: 0;
            }
            to {
                transform: translateY(0);
                opacity: 1;
            }
        }

        .alert-success {
            background: linear-gradient(135deg, var(--success-color) 0%, #17a673 100%);
            color: white;
        }

        .alert-danger {
            background: linear-gradient(135deg, var(--danger-color) 0%, #be2617 100%);
            color: white;
        }

        .alert-warning {
            background: linear-gradient(135deg, var(--warning-color) 0%, #daa20a 100%);
            color: white;
        }

        .alert-info {
            background: linear-gradient(135deg, var(--info-color) 0%, #258391 100%);
            color: white;
        }

        .btn-close {
            filter: brightness(0) invert(1);
        }

        .footer {
            background-color: white;
            box-shadow: 0 -0.15rem 1.75rem 0 rgba(58, 59, 69, 0.05);
            padding: 1.5rem 0;
            margin-top: 2rem;
        }

        .footer a {
            color: var(--primary-color);
            text-decoration: none;
            font-weight: 600;
        }

        .footer a:hover {
            text-decoration: underline;
        }

        main {
            min-height: calc(100vh - 150px);
            padding: 1.5rem 0;
        }

        /* Estilos para scrollbar personalizada */
        ::-webkit-scrollbar {
            width: 10px;
            height: 10px;
        }

        ::-webkit-scrollbar-track {
            background: #f1f1f1;
            border-radius: 5px;
        }

        ::-webkit-scrollbar-thumb {
            background: var(--primary-color);
            border-radius: 5px;
        }

        ::-webkit-scrollbar-thumb:hover {
            background: #224abe;
        }

        /* Estilos responsivos */
        @@media (max-width: 768px) {
            .navbar-brand {
                font-size: 1rem;
            }

            .nav-link i {
                margin-right: 0.25rem;
            }

            main {
                padding: 1rem 0;
            }

            .footer {
                padding: 1rem 0;
                font-size: 0.9rem;
            }
        }

        /* Utilidades adicionales */
        .cursor-pointer {
            cursor: pointer;
        }

        .text-gradient {
            background: linear-gradient(135deg, var(--primary-color) 0%, #224abe 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .border-left-primary {
            border-left: 4px solid var(--primary-color) !important;
        }

        .border-left-success {
            border-left: 4px solid var(--success-color) !important;
        }

        .border-left-info {
            border-left: 4px solid var(--info-color) !important;
        }

        .border-left-warning {
            border-left: 4px solid var(--warning-color) !important;
        }

        .border-left-danger {
            border-left: 4px solid var(--danger-color) !important;
        }

        /* Animaciones */
        .fade-in {
            animation: fadeIn 0.5s ease-in;
        }

        @@keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
    </style>
</head>
<body>
    @{
        var isLoggedIn = !string.IsNullOrEmpty(Context.Session.GetString("UserId"));
        var userName = Context.Session.GetString("UserName");
        var userRole = Context.Session.GetString("UserRole");
        var empNo = Context.Session.GetInt32("EmpNo");
    }

    @if (isLoggedIn)
    {
        <nav class="navbar navbar-expand-lg navbar-dark bg-primary sticky-top">
            <div class="container-fluid">
                <a class="navbar-brand" href="/">
                    <i class="fas fa-calculator"></i> Sistema de Nómina
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav"
                        aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link @(Context.Request.Path == "/" ? "active" : "")" href="/">
                                <i class="fas fa-home"></i> Inicio
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(Context.Request.Path.StartsWithSegments("/Employees") ? "active" : "")"
                               href="/Employees">
                                <i class="fas fa-users"></i> Empleados
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(Context.Request.Path.StartsWithSegments("/Departments") ? "active" : "")"
                               href="/Departments">
                                <i class="fas fa-building"></i> Departamentos
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(Context.Request.Path.StartsWithSegments("/Salaries") ? "active" : "")"
                               href="/Salaries">
                                <i class="fas fa-dollar-sign"></i> Salarios
                            </a>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle @(Context.Request.Path.StartsWithSegments("/Titles") ? "active" : "")"
                               href="#" id="titlesDropdown" role="button" data-bs-toggle="dropdown">
                                <i class="fas fa-briefcase"></i> Títulos
                            </a>
                            <ul class="dropdown-menu">
                                <li>
                                    <a class="dropdown-item" href="/Titles">
                                        <i class="fas fa-list"></i> Listado de Títulos
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" href="/Titles/Create">
                                        <i class="fas fa-plus-circle"></i> Nuevo Título
                                    </a>
                                </li>
                            </ul>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle @(Context.Request.Path.StartsWithSegments("/Reports") ? "active" : "")"
                               href="#" id="reportsDropdown" role="button" data-bs-toggle="dropdown">
                                <i class="fas fa-chart-bar"></i> Reportes
                            </a>
                            <ul class="dropdown-menu">
                                <li>
                                    <a class="dropdown-item" href="/Reports/NominaVigente">
                                        <i class="fas fa-file-invoice"></i> Nómina Vigente
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" href="/Reports/CambiosSalariales">
                                        <i class="fas fa-history"></i> Cambios Salariales
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" href="/Reports/EstructuraOrganizacional">
                                        <i class="fas fa-sitemap"></i> Estructura Organizacional
                                    </a>
                                </li>
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <a class="dropdown-item" href="/Reports/Auditoria">
                                        <i class="fas fa-clipboard-list"></i> Auditoría
                                    </a>
                                </li>
                            </ul>
                        </li>
                    </ul>
                    <ul class="navbar-nav ms-auto">
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" id="userDropdown" role="button"
                               data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="fas fa-user-circle"></i>
                                <span class="d-none d-lg-inline ms-1">@userName</span>
                                <span class="badge bg-warning ms-1">@userRole</span>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userDropdown">
                                <li>
                                    <a class="dropdown-item" href="/Employees/Details/@empNo">
                                        <i class="fas fa-id-card"></i> Mi Perfil
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" href="#">
                                        <i class="fas fa-cog"></i> Configuración
                                    </a>
                                </li>
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <a class="dropdown-item text-danger" href="/Account/Logout">
                                        <i class="fas fa-sign-out-alt"></i> Cerrar Sesión
                                    </a>
                                </li>
                            </ul>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>

        <!-- Barra de título de página -->
        <div class="bg-white border-bottom py-3">
            <div class="container-fluid">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h5 class="mb-0 text-gradient">@ViewData["Title"]</h5>
                        <nav aria-label="breadcrumb">
                            <ol class="breadcrumb mb-0 mt-1">
                                <li class="breadcrumb-item"><a href="/" class="text-decoration-none">Inicio</a></li>
                                @if (Context.Request.Path != "/")
                                {
                                    <li class="breadcrumb-item active" aria-current="page">@ViewData["Title"]</li>
                                }
                            </ol>
                        </nav>
                    </div>
                    <div>
                        @RenderSection("PageActions", required: false)
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- Mensajes de notificación -->
    @if (TempData["Success"] != null)
    {
        <div class="container-fluid mt-3">
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="fas fa-check-circle me-2"></i> @TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="container-fluid mt-3">
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="fas fa-exclamation-circle me-2"></i> @TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        </div>
    }

    @if (TempData["Warning"] != null)
    {
        <div class="container-fluid mt-3">
            <div class="alert alert-warning alert-dismissible fade show" role="alert">
                <i class="fas fa-exclamation-triangle me-2"></i> @TempData["Warning"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        </div>
    }

    @if (TempData["Info"] != null)
    {
        <div class="container-fluid mt-3">
            <div class="alert alert-info alert-dismissible fade show" role="alert">
                <i class="fas fa-info-circle me-2"></i> @TempData["Info"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        </div>
    }

    <!-- Contenido principal -->
    <main class="fade-in">
        <div class="container-fluid">
            @RenderBody()
        </div>
    </main>

    <!-- Footer -->
    <footer class="footer">
        <div class="container-fluid">
            <div class="row align-items-center">
                <div class="col-md-6 text-center text-md-start">
                    <span class="text-muted">
                        &copy; @DateTime.Now.Year - Sistema de Nómina v1.0
                    </span>
                </div>
                <div class="col-md-6 text-center text-md-end">
                    <a href="#" class="me-3">Privacidad</a>
                    <a href="#" class="me-3">Términos</a>
                    <a href="#">Contacto</a>
                </div>
            </div>
        </div>
    </footer>

    <!-- Scripts -->
    <script src="https://code.jquery.com/jquery-3.6.4.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Scripts personalizados -->
    <script>
        // Cerrar alertas automáticamente después de 5 segundos
        $(document).ready(function() {
            setTimeout(function() {
                $('.alert').alert('close');
            }, 5000);
        });

        // Tooltips personalizados
        var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'))
        var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
            return new bootstrap.Tooltip(tooltipTriggerEl)
        });

        // Popovers
        var popoverTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="popover"]'))
        var popoverList = popoverTriggerList.map(function (popoverTriggerEl) {
            return new bootstrap.Popover(popoverTriggerEl)
        });

        // Confirmación antes de cerrar sesión
        $('#logoutBtn').click(function(e) {
            e.preventDefault();
            if(confirm('¿Está seguro que desea cerrar la sesión?')) {
                window.location.href = '/Account/Logout';
            }
        });

        // Resaltar enlace activo en el menú
        $(document).ready(function() {
            var currentUrl = window.location.pathname;
            $('.navbar-nav .nav-link').each(function() {
                var linkUrl = $(this).attr('href');
                if(linkUrl && currentUrl.startsWith(linkUrl) && linkUrl !== '/') {
                    $(this).addClass('active');
                } else if(linkUrl === '/' && currentUrl === '/') {
                    $(this).addClass('active');
                }
            });
        });

        // Prevenir doble envío de formularios
        $('form').submit(function() {
            $(this).find('button[type="submit"]').prop('disabled', true);
        });

        // Filtros de búsqueda con debounce
        var searchTimeout;
        $('#searchInput').on('keyup', function() {
            clearTimeout(searchTimeout);
            searchTimeout = setTimeout(function() {
                $('#searchForm').submit();
            }, 500);
        });

        // Validación del lado del cliente
        $.validator.setDefaults({
            errorClass: 'invalid-feedback',
            highlight: function(element) {
                $(element).addClass('is-invalid');
            },
            unhighlight: function(element) {
                $(element).removeClass('is-invalid');
            },
            errorPlacement: function(error, element) {
                if (element.parent('.input-group').length) {
                    error.insertAfter(element.parent());
                } else {
                    error.insertAfter(element);
                }
            }
        });

        // Mostrar/ocultar contraseña
        $('.toggle-password').click(function() {
            var input = $($(this).data('target'));
            if (input.attr('type') === 'password') {
                input.attr('type', 'text');
                $(this).find('i').removeClass('fa-eye').addClass('fa-eye-slash');
            } else {
                input.attr('type', 'password');
                $(this).find('i').removeClass('fa-eye-slash').addClass('fa-eye');
            }
        });

        // Scroll suave
        $('a[href*="#"]').click(function(e) {
            if (location.pathname.replace(/^\//, '') == this.pathname.replace(/^\//, '')
                && location.hostname == this.hostname) {
                var target = $(this.hash);
                target = target.length ? target : $('[name=' + this.hash.slice(1) + ']');
                if (target.length) {
                    e.preventDefault();
                    $('html, body').animate({
                        scrollTop: target.offset().top - 70
                    }, 500);
                }
            }
        });

        // Notificaciones en tiempo real (simuladas)
        function checkNotifications() {
            $.get('/api/notifications', function(data) {
                if(data.count > 0) {
                    $('#notificationBadge').text(data.count).show();
                }
            });
        }

        // Verificar notificaciones cada 30 segundos
        if($('#notificationBadge').length) {
            setInterval(checkNotifications, 30000);
        }

        // Modo oscuro (opcional)
        $('#darkModeToggle').click(function() {
            $('body').toggleClass('dark-mode');
            localStorage.setItem('darkMode', $('body').hasClass('dark-mode'));
        });

        if(localStorage.getItem('darkMode') === 'true') {
            $('body').addClass('dark-mode');
        }

        // Manejo de errores AJAX global
        $(document).ajaxError(function(event, jqxhr, settings, thrownError) {
            console.log('Error AJAX:', thrownError);
            // Mostrar notificación de error
            var errorMsg = 'Error en la operación. Por favor, intente nuevamente.';
            if(jqxhr.status === 401) {
                errorMsg = 'Sesión expirada. Por favor, inicie sesión nuevamente.';
                window.location.href = '/Account/Login';
            }
            // Mostrar alerta de error
            var alertHtml = '<div class="alert alert-danger alert-dismissible fade show" role="alert">' +
                '<i class="fas fa-exclamation-circle me-2"></i>' + errorMsg +
                '<button type="button" class="btn-close" data-bs-dismiss="alert"></button>' +
                '</div>';
            $('main').prepend(alertHtml);
        });

        // Mejorar accesibilidad
        $('input, select, textarea').on('focus', function() {
            $(this).closest('.form-group').addClass('focused');
        }).on('blur', function() {
            $(this).closest('.form-group').removeClass('focused');
        });

        // Atajos de teclado
        $(document).keydown(function(e) {
            // Ctrl + S para guardar
            if(e.ctrlKey && e.keyCode === 83) {
                e.preventDefault();
                $('form').submit();
            }
            // Ctrl + N para nuevo
            if(e.ctrlKey && e.keyCode === 78) {
                e.preventDefault();
                var newUrl = $('.btn-primary[href*="Create"]').attr('href');
                if(newUrl) window.location.href = newUrl;
            }
            // Ctrl + F para buscar
            if(e.ctrlKey && e.keyCode === 70) {
                e.preventDefault();
                $('#searchInput').focus();
            }
            // Escape para cerrar modales
            if(e.keyCode === 27) {
                $('.modal').modal('hide');
            }
        });

        // Cargar contenido con spinner
        $(document).ajaxStart(function() {
            $('#globalSpinner').show();
        }).ajaxStop(function() {
            $('#globalSpinner').hide();
        });

        // Inicializar select2 si existe
        if($.fn.select2) {
            $('.select2').select2({
                theme: 'bootstrap-5'
            });
        }

        // Inicializar datepicker si existe
        if($.fn.datepicker) {
            $('.datepicker').datepicker({
                format: 'dd/mm/yyyy',
                language: 'es',
                autoclose: true
            });
        }
    </script>

    <!-- Spinner global -->
    <div id="globalSpinner" style="display: none; position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); z-index: 9999;">
        <div class="spinner-border text-primary" role="status" style="width: 3rem; height: 3rem;">
            <span class="visually-hidden">Cargando...</span>
        </div>
    </div>

    <!-- Botón para volver arriba -->
    <button id="backToTop" class="btn btn-primary rounded-circle position-fixed bottom-0 end-0 m-4"
            style="display: none; width: 50px; height: 50px; z-index: 1000;" onclick="scrollToTop()">
        <i class="fas fa-arrow-up"></i>
    </button>

    <script>
        function scrollToTop() {
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        window.onscroll = function() {
            if (document.body.scrollTop > 20 || document.documentElement.scrollTop > 20) {
                document.getElementById('backToTop').style.display = 'block';
            } else {
                document.getElementById('backToTop').style.display = 'none';
            }
        };
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>