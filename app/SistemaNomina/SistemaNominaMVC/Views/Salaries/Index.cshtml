@model IEnumerable<SistemaNominaMVC.Models.Salary>
@{
    ViewData["Title"] = "Gestión de Salarios";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3">@ViewData["Title"]</h1>
        <a asp-action="Create" class="btn btn-primary">
            <i class="fas fa-plus"></i> Nuevo Salario
        </a>
    </div>

    <!-- Filtros de búsqueda -->
    <div class="card shadow mb-4">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">Filtros de Búsqueda</h6>
        </div>
        <div class="card-body">
            <form asp-action="Index" method="get" class="row g-3">
                <div class="col-md-4">
                    <label class="form-label">Buscar por empleado</label>
                    <div class="input-group">
                        <input type="text" class="form-control" name="searchString"
                               value="@ViewData["CurrentFilter"]"
                               placeholder="Nombre, CI o email..." />
                        <button class="btn btn-primary" type="submit">
                            <i class="fas fa-search"></i>
                        </button>
                    </div>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Filtrar por empleado</label>
                    <select name="employeeId" class="form-select" asp-items="ViewBag.Employees"
                            onchange="this.form.submit()">
                        <option value="">Todos los empleados</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Estado</label>
                    <select name="estado" class="form-select" onchange="this.form.submit()">
                        <option value="">Todos</option>
                        <option value="activos" selected="@(ViewData["Estado"]?.ToString() == "activos")">
                            Salarios Activos
                        </option>
                        <option value="historicos" selected="@(ViewData["Estado"]?.ToString() == "historicos")">
                            Históricos
                        </option>
                    </select>
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <a asp-action="Index" class="btn btn-secondary w-100">
                        <i class="fas fa-undo"></i> Limpiar
                    </a>
                </div>
            </form>
        </div>
    </div>

    <!-- Tabla de salarios -->
    <div class="card shadow">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">Listado de Salarios</h6>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered table-hover" id="dataTable" width="100%" cellspacing="0">
                    <thead class="table-light">
                        <tr>
                            <th>Empleado</th>
                            <th>CI</th>
                            <th>Salario</th>
                            <th>Fecha Inicio</th>
                            <th>Fecha Fin</th>
                            <th>Estado</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    <a asp-controller="Employees" asp-action="Details" asp-route-id="@item.emp_no">
                                        @item.Employee?.first_name @item.Employee?.last_name
                                    </a>
                                </td>
                                <td>@item.Employee?.ci</td>
                                <td class="text-end fw-bold">@item.salary.ToString("C2")</td>
                                <td>@item.from_date.ToString("dd/MM/yyyy")</td>
                                <td>@(item.to_date?.ToString("dd/MM/yyyy") ?? "Actual")</td>
                                <td>
                                    @if (item.to_date == null)
                                    {
                                        <span class="badge bg-success">Activo</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Histórico</span>
                                    }
                                </td>
                                <td>
                                    <div class="btn-group" role="group">
                                        <a asp-action="History" asp-route-employeeId="@item.emp_no"
                                           class="btn btn-info btn-sm" title="Ver historial">
                                            <i class="fas fa-history"></i>
                                        </a>
                                        @if (item.to_date == null)
                                        {
                                            <button type="button" class="btn btn-warning btn-sm"
                                                    onclick="showCloseModal(@item.Id, '@item.Employee?.first_name @item.Employee?.last_name', '@item.salary.ToString("C2")')"
                                                    title="Cerrar salario">
                                                <i class="fas fa-times-circle"></i>
                                            </button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>

                @if (!Model.Any())
                {
                    <div class="alert alert-info text-center">
                        <i class="fas fa-info-circle"></i> No hay salarios registrados
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<!-- Modal para cerrar salario -->
<div class="modal fade" id="closeSalaryModal" tabindex="-1" aria-labelledby="closeSalaryModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-warning">
                <h5 class="modal-title text-white" id="closeSalaryModalLabel">
                    <i class="fas fa-exclamation-triangle"></i> Confirmar cierre de salario
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p>¿Está seguro que desea cerrar el salario de <strong id="employeeName"></strong>?</p>
                <p>Salario actual: <strong id="salaryAmount"></strong></p>
                <div class="alert alert-warning">
                    <i class="fas fa-clock"></i> El salario se cerrará con fecha de hoy
                </div>
            </div>
            <div class="modal-footer">
                <form asp-action="Close" method="post">
                    <input type="hidden" name="id" id="salaryId" value="" />
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-warning">Cerrar Salario</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function showCloseModal(id, employeeName, salary) {
            document.getElementById('salaryId').value = id;
            document.getElementById('employeeName').textContent = employeeName;
            document.getElementById('salaryAmount').textContent = salary;
            new bootstrap.Modal(document.getElementById('closeSalaryModal')).show();
        }

        // DataTables inicialización (opcional)
        $(document).ready(function() {
            if ($.fn.DataTable) {
                $('#dataTable').DataTable({
                    language: {
                        url: '//cdn.datatables.net/plug-ins/1.13.4/i18n/es-ES.json'
                    },
                    pageLength: 25,
                    order: [[3, 'desc']]
                });
            }
        });
    </script>
}