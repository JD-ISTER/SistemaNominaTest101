@model IEnumerable<SistemaNominaMVC.Models.ViewModels.CambioSalarialViewModel>
@{
    ViewData["Title"] = "Cambios Salariales";
    var fechaInicio = ViewBag.FechaInicio as DateTime? ?? DateTime.Today.AddMonths(-1);
    var fechaFin = ViewBag.FechaFin as DateTime? ?? DateTime.Today;
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3">@ViewData["Title"]</h1>
        <div>
            <button onclick="exportToExcel()" class="btn btn-success">
                <i class="fas fa-file-excel"></i> Exportar Excel
            </button>
            <a asp-action="Index" class="btn btn-secondary">
                <i class="fas fa-arrow-left"></i> Volver
            </a>
        </div>
    </div>

    <!-- Filtros de fecha -->
    <div class="card shadow mb-4">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">Filtrar por período</h6>
        </div>
        <div class="card-body">
            <form method="get" class="row g-3">
                <div class="col-md-4">
                    <label class="form-label">Fecha Inicio</label>
                    <input type="date" class="form-control" name="fechaInicio"
                           value="@fechaInicio.ToString("yyyy-MM-dd")" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Fecha Fin</label>
                    <input type="date" class="form-control" name="fechaFin"
                           value="@fechaFin.ToString("yyyy-MM-dd")" />
                </div>
                <div class="col-md-4 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary me-2">
                        <i class="fas fa-search"></i> Filtrar
                    </button>
                    <a asp-action="CambiosSalariales" class="btn btn-secondary">
                        <i class="fas fa-undo"></i> Limpiar
                    </a>
                </div>
            </form>
        </div>
    </div>

    <!-- Resumen de cambios -->
    <div class="row mb-4">
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-left-primary shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">
                                Total Cambios
                            </div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">@ViewBag.TotalCambios</div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-history fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-left-success shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-success text-uppercase mb-1">
                                Empleados Afectados
                            </div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">@ViewBag.EmpleadosAfectados</div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-users fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-left-info shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-info text-uppercase mb-1">
                                Incremento Promedio
                            </div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">
                                @ViewBag.IncrementoPromedio?.ToString("C2")
                            </div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-chart-line fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-left-warning shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-warning text-uppercase mb-1">
                                Monto Total Cambios
                            </div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">
                                @ViewBag.MontoTotal?.ToString("C2")
                            </div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-dollar-sign fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Tabla de cambios -->
    <div class="card shadow">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">Registro de Cambios Salariales</h6>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered table-hover" id="dataTable">
                    <thead class="table-light">
                        <tr>
                            <th>Fecha</th>
                            <th>Usuario</th>
                            <th>Empleado</th>
                            <th>CI</th>
                            <th>Tipo</th>
                            <th>Detalle del Cambio</th>
                            <th>Salario Anterior</th>
                            <th>Nuevo Salario</th>
                            <th>Incremento</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.OrderByDescending(l => l.FechaActualizacion))
                        {
                            <tr>
                                <td>@item.FechaActualizacion.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>@item.Usuario</td>
                                <td>@item.NombreEmpleado @item.ApellidoEmpleado</td>
                                <td>@item.CIEmpleado</td>
                                <td>
                                    @if (item.TipoCambio == "Creación")
                                    {
                                        <span class="badge bg-success">Creación</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning">Modificación</span>
                                    }
                                </td>
                                <td>@item.DetalleCambio</td>
                                <td class="text-end">@(item.SalarioAnterior?.ToString("C2") ?? "-")</td>
                                <td class="text-end fw-bold">@item.Salario.ToString("C2")</td>
                                <td class="text-end @(item.Incremento > 0 ? "text-success" : "text-danger")">
                                    @if (item.Incremento.HasValue && item.Incremento != 0)
                                    {
                                        @(item.Incremento > 0 ? "+" : "")
                                        @item.Incremento.Value.ToString("C2")
                                    }
                                </td>
                                <td>
                                    <a asp-controller="Employees" asp-action="Details"
                                       asp-route-id="@item.EmpleadoId" class="btn btn-info btn-sm">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    <a asp-controller="Salaries" asp-action="History"
                                       asp-route-employeeId="@item.EmpleadoId" class="btn btn-primary btn-sm">
                                        <i class="fas fa-history"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>

                @if (!Model.Any())
                {
                    <div class="alert alert-info text-center">
                        <i class="fas fa-info-circle"></i> No hay registros de cambios salariales en el período seleccionado
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            if ($.fn.DataTable) {
                $('#dataTable').DataTable({
                    language: {
                        url: '//cdn.datatables.net/plug-ins/1.13.4/i18n/es-ES.json'
                    },
                    pageLength: 25,
                    order: [[0, 'desc']]
                });
            }
        });

        function exportToExcel() {
            var fechaInicio = $('input[name="fechaInicio"]').val();
            var fechaFin = $('input[name="fechaFin"]').val();
            window.location.href = '@Url.Action("ExportarExcel", "Reports")?tipo=cambios&fechaInicio=' +
                                  fechaInicio + '&fechaFin=' + fechaFin;
        }

        function exportToPDF() {
            var fechaInicio = $('input[name="fechaInicio"]').val();
            var fechaFin = $('input[name="fechaFin"]').val();
            window.location.href = '@Url.Action("ExportarPDF", "Reports")?tipo=cambios&fechaInicio=' +
                                  fechaInicio + '&fechaFin=' + fechaFin;
        }
    </script>
}